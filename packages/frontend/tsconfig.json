{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "outDir": "dist",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "composite": false,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@shulkr/frontend/*": ["./src/*"],
      "@shulkr/backend/*": ["../backend/src/*"],
      "@shulkr/shared": ["../shared/src"],
      "@shulkr/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "../backend/**/*", "vite.config.ts"]
}
