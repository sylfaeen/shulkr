{
  "name": "@shulkr/backend",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env --import=./src/env.ts src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit && eslint --fix src/ && prettier --check --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1032.0",
    "@aws-sdk/lib-storage": "^3.1032.0",
    "@fastify/cookie": "^10",
    "@fastify/cors": "^10",
    "@fastify/helmet": "^12",
    "@fastify/jwt": "^9",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@shulkr/shared": "workspace:*",
    "@ts-rest/core": "^3.52.1",
    "@ts-rest/fastify": "^3.52.1",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "bcrypt": "^5",
    "better-sqlite3": "^11",
    "drizzle-orm": "^0.35",
    "fastify": "^5",
    "fastify-plugin": "^5.1.0",
    "js-yaml": "^4.1.1",
    "otpauth": "^9.5.0",
    "pidusage": "^4.0.1",
    "sharp": "^0.34.5",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^5",
    "@types/better-sqlite3": "^7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22",
    "@types/pidusage": "^2.0.5",
    "drizzle-kit": "^0.26",
    "tsup": "^8.5.1",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^2"
  }
}
