{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@shulkr/backend/*": ["./src/*"],
      "@shulkr/shared": ["../shared/src"],
      "@shulkr/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src/**/*", "src/**/*.json"],
  "exclude": ["node_modules", "dist"],
  "references": [{ "path": "../shared" }]
}
