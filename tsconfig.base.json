{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "@shulkr/shared": ["packages/shared/src"],
      "@shulkr/shared/*": ["packages/shared/src/*"],
      "@shulkr/backend/*": ["packages/backend/src/*"],
      "@shulkr/frontend/*": ["packages/frontend/src/*"]
    }
  }
}
